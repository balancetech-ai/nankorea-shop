<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title><%= title %> | 한국난원</title>
<link rel="shortcut icon" href="/shop/resources/img/favicon.ico">
<link rel="stylesheet" href="/shop/resources/css/style01.css">
<link rel="stylesheet" media="handheld" href="/shop/resources/css/handheld.css">
<script type="text/javascript">var DOC = { ROOT : "/shop/" };</script>
<script type="text/javascript" src="/shop/resources/js/lib/jquery-1.7.1.min.js"></script>
</head>
<body>
<div class="mainwrapper">

    <!-- ☆☆☆ header ☆☆☆ -->
    <header>
        <h1>
            <a href="<%= base %>/">
                <img src="<%= imgShop('headerLogo_20240823140448511.png') %>" alt="한국난원"/>
            </a>
        </h1>
        <address>
            <img src="<%= imgShop('headerTelephone_20240823144222256.png') %>" alt="전화" width="138px" height="118px"/>
        </address>

        <nav class="topmenuleft">
            <ul>
                <li class="d01"><a href="#">이용안내</a></li>
                <li class="d02"><a href="#">전화주문안내</a></li>
                <li class="d03"><a href="#">즐겨찾기</a></li>
            </ul>
            <form action="<%= base %>/search" method="get" id="headerSearchForm">
                <fieldset>
                    <legend>상품검색</legend>
                    <label>상품검색</label><input type="text" class="searchWord" name="productName" value="<%= typeof q !== 'undefined' ? q : '' %>">
                    <button type="submit">검색</button>
                </fieldset>
            </form>
        </nav>

        <nav class="topmenuright">
            <ol>
                <li class="login"><a href="<%= base %>/login">로그인</a></li>
                <li class="join"><a href="<%= base %>/login">회원가입</a></li>
                <li class="orderCheck"><a href="<%= base %>/login">주문조회</a></li>
                <li class="shopGuide"><a href="#">쇼핑가이드</a></li>
            </ol>
        </nav>

        <div id="div_notice">
            <article class="topnotice">
                <h3><a href="#">공지사항</a></h3>
                <ol id="newstickerlist"><li><p><a href="#">한국난원 쇼핑몰을 찾아주셔서 감사합니다.</a></p></li></ol>
            </article>
        </div>

        <nav class="mainmenu">
            <h1>모든 카테고리</h1>
            <ul>
                <% navCategories.forEach((c) => { %>
                    <li><a href="<%= base %>/category/<%= c.id %>"><%= c.name %></a></li>
                <% }) %>
            </ul>
            <ol>
                <% usageCategories.forEach((c, i) => { const m = 'm0' + (i + 1); %>
                    <li class="<%= m %>"><a href="<%= base %>/category/<%= c.id %>" class="<%= m %>"><%= c.name %></a></li>
                <% }) %>
            </ol>
        </nav>
    </header>
    <!-- ☆☆☆ header e ☆☆☆ -->
