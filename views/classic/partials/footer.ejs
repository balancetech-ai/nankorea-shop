<!-- 퀵메뉴 스크롤 따라가기 (원본 script.js의 initializequick 로직 자체포함) -->
<script>
(function () {
    var q = document.getElementById('quickMenu');
    if (!q) return;
    var LEFT = 1010, VIEWSTART = 85, VIEWSCROLL = 30, VIEWBOTTOM = 80, SPEED = 10;
    q.style.position = 'absolute';
    q.style.left = LEFT + 'px';
    q.style.right = 'auto';
    function scrollY() { return Math.max(document.documentElement.scrollTop, document.body.scrollTop, window.pageYOffset || 0); }
    q.style.top = (scrollY() + VIEWSTART) + 'px';
    function refresh() {
        var bottomlimit = document.documentElement.scrollHeight - VIEWBOTTOM - q.offsetHeight;
        var start = parseInt(q.style.top, 10) || 0;
        var end = scrollY() + VIEWSCROLL;
        if (end < VIEWSTART) end = VIEWSTART;
        if (end > bottomlimit) end = bottomlimit;
        if (start !== end) {
            var amt = Math.ceil(Math.abs(end - start) / 15);
            q.style.top = (start + (end < start ? -amt : amt)) + 'px';
        }
        setTimeout(refresh, SPEED);
    }
    refresh();
})();
</script>
