<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - 한국난원</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/kurly.css">
    <link rel="stylesheet" href="/css/shop.css">
</head>
<body>

    <div class="top-bar">
        <div class="inner flex-between">
            <div class="top-left">
                <a href="#"><i class="fa-solid fa-bell"></i> 공지사항</a>
                <a href="#"><i class="fa-solid fa-circle-question"></i> 이용안내</a>
            </div>
            <div class="top-right">
                <a href="<%= base %>/login">로그인</a>
                <a href="<%= base %>/login">회원가입</a>
                <a href="<%= base %>/login" class="highlight">주문조회</a>
                <a href="#">고객센터</a>
            </div>
        </div>
    </div>

    <header class="main-header">
        <div class="inner flex-between">
            <form class="search-form" action="<%= base %>/search" method="get">
                <input type="text" name="productName" placeholder="어떤 식물을 찾으시나요?" value="<%= typeof q !== 'undefined' ? q : '' %>">
                <button type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
            </form>

            <div class="logo">
                <a href="<%= base %>/">KOREA NANWON<span>한국난원</span></a>
            </div>

            <div class="header-icons">
                <a href="#" title="장바구니"><i class="fa-solid fa-bag-shopping"></i><span class="badge">0</span></a>
                <a href="#" title="마이페이지"><i class="fa-solid fa-user"></i></a>
            </div>
        </div>
    </header>

    <nav class="main-nav">
        <div class="inner">
            <ul class="menu-list">
                <li><a href="<%= base %>/" class="<%= currentCategory ? '' : 'active' %>">Home</a></li>
                <% navCategories.forEach((c) => { %>
                    <li><a href="<%= base %>/category/<%= c.id %>" class="<%= currentCategory === c.id ? 'active' : '' %>"><%= c.name %></a></li>
                <% }) %>
            </ul>
        </div>
    </nav>
