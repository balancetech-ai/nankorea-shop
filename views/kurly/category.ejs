<%- include('partials/header') %>

    <div class="page-head">
        <div class="inner">
            <nav class="breadcrumb">
                <a href="<%= base %>/">Home</a> <i class="fa-solid fa-angle-right"></i>
                <span><%= category.name %></span>
            </nav>
            <h2><%= category.name %> <em><%= products.length %></em></h2>
        </div>
    </div>

    <main class="main-products" style="padding-top:24px;">
        <div class="inner">
            <% if (products.length === 0) { %>
                <p class="empty">등록된 상품이 없습니다.</p>
            <% } else { %>
                <div class="product-grid">
                    <% products.forEach((p) => { %>
                        <%- include('partials/product-card', { p }) %>
                    <% }) %>
                </div>
            <% } %>
        </div>
    </main>

<%- include('partials/footer') %>
