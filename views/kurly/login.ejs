<%- include('partials/header') %>

    <div class="page-head">
        <div class="inner">
            <nav class="breadcrumb"><a href="<%= base %>/">Home</a> <i class="fa-solid fa-angle-right"></i> <span>로그인</span></nav>
        </div>
    </div>

    <main class="main-products">
        <div class="inner" style="max-width:380px; margin:0 auto; padding:20px 0 80px;">
            <h3 style="text-align:center; font-size:22px; font-weight:700; margin-bottom:24px;">로그인</h3>
            <form onsubmit="alert('실제 로그인은 블루마 DB 연동(3단계)에서 활성화됩니다.'); return false;">
                <input type="text" placeholder="아이디" style="width:100%; height:48px; border:1px solid #ddd; border-radius:6px; padding:0 14px; margin-bottom:10px; font-size:14px;">
                <input type="password" placeholder="비밀번호" style="width:100%; height:48px; border:1px solid #ddd; border-radius:6px; padding:0 14px; margin-bottom:16px; font-size:14px;">
                <button type="submit" style="width:100%; height:52px; background:#5f0080; color:#fff; border:none; border-radius:6px; font-size:16px; font-weight:700; cursor:pointer;">로그인</button>
            </form>
            <p style="text-align:center; color:#999; font-size:13px; margin-top:16px;">회원가입 · 비회원 주문은 3단계(DB 연동)에서 활성화됩니다.</p>
        </div>
    </main>

<%- include('partials/footer') %>
