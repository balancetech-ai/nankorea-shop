<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %> | 한국난원 관리자</title>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<header class="adm-top">
    <div class="adm-top-inner">
        <a href="/admin" class="adm-logo"><i class="fa-solid fa-leaf"></i> 한국난원 <small>관리자</small></a>
        <nav class="adm-nav">
            <a href="/admin" class="<%= typeof active !== 'undefined' && active === 'dashboard' ? 'on' : '' %>">대시보드</a>
            <a href="/admin/products" class="<%= typeof active !== 'undefined' && active === 'products' ? 'on' : '' %>">상품관리</a>
            <a href="/admin/categories" class="<%= typeof active !== 'undefined' && active === 'categories' ? 'on' : '' %>">카테고리</a>
        </nav>
        <div class="adm-right">
            <a href="/?pc=1" target="_blank" class="adm-ghost"><i class="fa-solid fa-store"></i> 쇼핑몰 보기</a>
            <a href="/admin/logout" class="adm-ghost"><i class="fa-solid fa-right-from-bracket"></i> 로그아웃</a>
        </div>
    </div>
</header>
<main class="adm-main">
