<% var active='dashboard' %><%- include('partials/head') %>

    <div class="adm-head">
        <h1>대시보드</h1>
    </div>

    <div class="adm-cards">
        <div class="adm-card"><span class="num"><%= productCount %></span><span class="lbl">등록 상품</span><a href="/admin/products">상품관리 →</a></div>
        <div class="adm-card"><span class="num"><%= categoryCount %></span><span class="lbl">카테고리</span><a href="/admin/categories">카테고리 →</a></div>
        <div class="adm-card warn"><span class="num"><%= noImageCount %></span><span class="lbl">이미지 없는 상품</span><a href="/admin/products">확인 →</a></div>
        <div class="adm-card go"><span class="num"><i class="fa-solid fa-plus"></i></span><span class="lbl">새 상품 등록</span><a href="/admin/products/new">등록하기 →</a></div>
    </div>

    <div class="adm-head"><h2>최근 등록/수정 상품</h2></div>
    <div class="adm-recent">
        <% recent.forEach((p) => { %>
            <a href="/admin/products/<%= p.productId %>/edit" class="r-item">
                <div class="r-thumb"><% if (p.images && p.images.medium) { %><img src="<%= imgProd(p.images.medium) %>" alt=""><% } else { %><i class="fa-solid fa-image"></i><% } %></div>
                <div class="r-name"><%= p.name %></div>
                <div class="r-price"><%= fmtPrice(p.price) %></div>
            </a>
        <% }) %>
    </div>

<%- include('partials/foot') %>
