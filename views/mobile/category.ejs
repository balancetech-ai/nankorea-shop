<%- include('partials/header') %>

    <div class="m-cats">
        <% navCategories.forEach((c) => { %>
            <a href="<%= base %>/category/<%= c.id %>" class="<%= currentCategory === c.id ? 'on' : '' %>"><%= c.name %></a>
        <% }) %>
        <% usageCategories.forEach((c) => { %>
            <a href="<%= base %>/category/<%= c.id %>" class="<%= currentCategory === c.id ? 'on' : '' %>"><%= c.name %></a>
        <% }) %>
    </div>

    <div class="m-listhead">
        <h1><%= category.name %> <em><%= total %></em></h1>
    </div>

    <div class="m-sort">
        <a href="<%= base %>/category/<%= category.id %>" class="<%= !sort ? 'on' : '' %>">기본</a>
        <a href="<%= base %>/category/<%= category.id %>?sort=name" class="<%= sort === 'name' ? 'on' : '' %>">이름순</a>
        <a href="<%= base %>/category/<%= category.id %>?sort=low" class="<%= sort === 'low' ? 'on' : '' %>">낮은가격</a>
        <a href="<%= base %>/category/<%= category.id %>?sort=high" class="<%= sort === 'high' ? 'on' : '' %>">높은가격</a>
    </div>

    <% if (products.length === 0) { %>
        <p class="m-empty">해당 조건의 상품이 없습니다.</p>
    <% } else { %>
        <div class="m-grid">
            <% products.forEach((p) => { %><%- include('partials/card', { p }) %><% }) %>
        </div>

        <%
          function pgUrl(n) {
            const q = [];
            if (sort) q.push('sort=' + sort);
            if (min) q.push('min=' + min);
            if (max) q.push('max=' + max);
            q.push('page=' + n);
            return base + '/category/' + category.id + '?' + q.join('&');
          }
        %>
        <% if (totalPages > 1) { %>
        <nav class="m-paging">
            <% if (page > 1) { %><a href="<%= pgUrl(page - 1) %>">이전</a><% } %>
            <% for (let n = 1; n <= totalPages; n++) { %>
                <% if (n === page) { %><span class="on"><%= n %></span><% } else { %><a href="<%= pgUrl(n) %>"><%= n %></a><% } %>
            <% } %>
            <% if (page < totalPages) { %><a href="<%= pgUrl(page + 1) %>">다음</a><% } %>
        </nav>
        <% } %>
    <% } %>

    <style>
    .m-paging { display:flex; flex-wrap:wrap; justify-content:center; gap:6px; margin:20px 12px; }
    .m-paging a, .m-paging span { min-width:34px; height:34px; display:flex; align-items:center; justify-content:center; padding:0 8px; border:1px solid #e3e3e3; border-radius:6px; font-size:13px; color:#333; text-decoration:none; }
    .m-paging span.on { background:#222; border-color:#222; color:#fff; font-weight:700; }
    </style>

<%- include('partials/footer') %>
