# ────────────────────────────────────────────────────────────
# 환경변수 템플릿. 이 파일을 복사해 `.env` 로 만들고 실제 값을 채우세요.
#   cp .env.example .env
# 실제 .env 는 git에 올라가지 않습니다(.gitignore). 값은 운영자에게 별도 수령.
# ────────────────────────────────────────────────────────────

# 서버 포트 (기본 3000)
PORT=3000

# 관리자(/admin) 로그인 비밀번호 — 운영 전 반드시 변경
ADMIN_PASSWORD=

# 블루마 운영 DB (읽기전용 동기화 `npm run sync` 에만 사용. 서버 구동 자체엔 불필요)
# 실제 접속정보는 운영자에게 안전한 채널로 수령. DB는 SELECT만, 절대 쓰지 않음.
DB_HOST=
DB_PORT=
DB_USER=
DB_PASS=
DB_NAME=
